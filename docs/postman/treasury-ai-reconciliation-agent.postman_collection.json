{
  "info": {
    "_postman_id": "1c6c9d64-7770-45cf-9d1d-2bb9a6c3b1f1",
    "name": "Treasury AI Reconciliation Agent",
    "description": "Smoke-test collection for the AI Marathon 2026 Global Treasury Agent API. Defaults to the hosted Render backend; change base_url to http://localhost:8000 for local DEMO_MODE=true verification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "CORS Preflight - Vercel Upload",
      "request": {
        "method": "OPTIONS",
        "header": [
          {
            "key": "Origin",
            "value": "{{frontend_url}}"
          },
          {
            "key": "Access-Control-Request-Method",
            "value": "POST"
          },
          {
            "key": "Access-Control-Request-Headers",
            "value": "content-type"
          }
        ],
        "url": "{{base_url}}/api/upload"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('hosted frontend origin is allowed', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.eql(pm.collectionVariables.get('frontend_url'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Demo - Matched",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/demo?case=matched"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('matched demo returns reconciliation result', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('matched');",
              "  pm.expect(json.job_id).to.be.a('string');",
              "  pm.collectionVariables.set('job_id', json.job_id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Demo - Needs Review",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/demo?case=needs_review"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('needs_review demo returns reconciliation result', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('needs_review');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Demo - Unmatched",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/demo?case=unmatched"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('unmatched demo returns reconciliation result', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('unmatched');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Upload Files - Live FX Sample",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "invoice",
              "type": "file",
              "src": "data/demo/live_fx_upload_test/invoice_INV-LIVE-2026-0526.png"
            },
            {
              "key": "payment_proof",
              "type": "file",
              "src": "data/demo/live_fx_upload_test/payment_proof_INV-LIVE-2026-0526.png"
            },
            {
              "key": "bank_statement",
              "type": "file",
              "src": "data/demo/live_fx_upload_test/bank_statement_live_fx.csv"
            }
          ]
        },
        "url": "{{base_url}}/api/upload"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('upload returns stored reconciliation result', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.job_id).to.match(/^upload_/);",
              "  pm.expect(json.status).to.eql('matched');",
              "  pm.expect(json.invoice.invoice_number).to.eql('INV-LIVE-2026-0526');",
              "  pm.expect(json.best_match.row_id).to.eql('live_row_002');",
              "  pm.expect(json.fee_trace.expected_credit).to.eql(968.92);",
              "  pm.collectionVariables.set('job_id', json.job_id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Reconcile Stored Upload Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"job_id\": \"{{job_id}}\"\n}"
        },
        "url": "{{base_url}}/api/reconcile"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('stored job can be reconciled by id', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.job_id).to.eql(pm.collectionVariables.get('job_id'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Download PDF Report",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/report/{{job_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('report downloads as PDF', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Download CSV Audit Export",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/export/{{job_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('audit export downloads as CSV', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://global-treasury-agent.onrender.com"
    },
    {
      "key": "frontend_url",
      "value": "https://global-treasury-agent.vercel.app"
    },
    {
      "key": "job_id",
      "value": "demo_001"
    }
  ]
}
